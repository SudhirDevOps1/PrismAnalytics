# =============================================================================
# PrismAnalytics — Environment Variables
# Copy this to .env and fill values. Never commit .env to git.
# =============================================================================

# ---- Database (Next.js local dev + production) ----
# PostgreSQL connection string for local dev / Next.js preview
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/app_db

# ---- Auth / Security (IMPORTANT: change in production!) ----
# 32+ random chars, e.g. `openssl rand -base64 48`
JWT_SECRET=change-this-to-a-very-long-random-secret-min-32-chars

# ---- Cloudflare (Wrangler uses CLOUDFLARE_API_TOKEN env) ----
# Set via `npx wrangler login` or env vars:
# CLOUDFLARE_API_TOKEN=your-api-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# ---- App URL (used for CORS + OG) ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_URL=https://prism-analytics.example.workers.dev

# ---- Optional: Email (for alerts, if you integrate Resend / Postmark) ----
# RESEND_API_KEY=re_xxx
# ALERT_EMAIL=alerts@yourdomain.com

# ---- Optional: R2 archiving ----
# R2 is managed via wrangler.toml binding, not env, but bucket name:
R2_BUCKET_NAME=prism-analytics-storage

# ---- Optional: Rate limit tuning ----
# RATE_LIMIT_TRACK_WINDOW_MS=60000
# RATE_LIMIT_TRACK_MAX=300
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=10
